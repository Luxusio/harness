{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/session_context.py",
            "timeout": 10,
            "statusMessage": "Loading harness context"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/task_created_gate.py",
            "timeout": 10,
            "statusMessage": "Initializing task artifacts"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/task_completed_gate.py",
            "timeout": 15,
            "statusMessage": "Verifying task completion"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/subagent_stop_gate.py",
            "timeout": 10,
            "statusMessage": "Checking subagent artifacts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/stop_gate.py",
            "timeout": 10,
            "statusMessage": "Checking open tasks"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/prewrite_gate.py",
            "timeout": 3,
            "statusMessage": "Checking write gate"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/file_changed_sync.py",
            "timeout": 5,
            "statusMessage": "Syncing verdict state"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/post_compact_sync.py",
            "timeout": 10,
            "statusMessage": "Recovering task context"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/session_end_sync.py",
            "timeout": 10,
            "statusMessage": "Recording session state"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/prompt_memory.py",
            "timeout": 5,
            "statusMessage": "Loading context hints"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/tool_routing.py",
            "timeout": 3,
            "statusMessage": "Checking tool hints"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/teammate_idle_gate.py",
            "timeout": 5,
            "statusMessage": "Checking teammate artifacts"
          }
        ]
      }
    ]
  }
}
