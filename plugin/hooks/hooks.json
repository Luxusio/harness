{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/session-context.sh",
            "timeout": 10,
            "statusMessage": "Loading harness context"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/task-created-gate.sh",
            "timeout": 10,
            "statusMessage": "Initializing task artifacts"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/task-completed-gate.sh",
            "timeout": 15,
            "statusMessage": "Verifying task completion"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/subagent-stop-gate.sh",
            "timeout": 10,
            "statusMessage": "Checking subagent artifacts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/stop-gate.sh",
            "timeout": 10,
            "statusMessage": "Checking open tasks"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/file-changed-sync.sh",
            "timeout": 5,
            "statusMessage": "Syncing verdict state"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/post-compact-sync.sh",
            "timeout": 10,
            "statusMessage": "Recovering task context"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/session-end-sync.sh",
            "timeout": 10,
            "statusMessage": "Recording session state"
          }
        ]
      }
    ]
  }
}
