{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-context.sh",
            "timeout": 10,
            "statusMessage": "Loading harness context"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/task-created-gate.sh",
            "timeout": 10,
            "statusMessage": "Initializing task artifacts"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/task-completed-gate.sh",
            "timeout": 10,
            "statusMessage": "Verifying task completion"
          }
        ]
      }
    ]
  }
}
