#!/usr/bin/env python3
"""Read review log entries for the current branch from doc/harness/reviews/{branch}-reviews.jsonl."""

import os
import subprocess
import sys


def get_branch():
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--abbrev-ref", "HEAD"],
            capture_output=True,
            text=True,
            check=True,
        )
        branch = result.stdout.strip()
        return branch.replace("/", "-") if branch else "unknown"
    except Exception:
        return "unknown"


def main():
    branch = get_branch()

    try:
        repo_root = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True,
            text=True,
            check=True,
        ).stdout.strip()
    except Exception:
        repo_root = os.getcwd()

    path = os.path.join(repo_root, "doc", "harness", "reviews", f"{branch}-reviews.jsonl")

    if not os.path.exists(path):
        print("NO_REVIEWS")
        sys.exit(0)

    with open(path, "r", encoding="utf-8") as fh:
        lines = fh.readlines()

    for line in lines:
        line = line.rstrip("\n")
        if line:
            print(line)

    print("---CONFIG---")


if __name__ == "__main__":
    main()
